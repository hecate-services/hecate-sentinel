%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_sentinel
%%
%% Layer-2 hecate-om service: the threat brain. It hears the wardens' reports off
%% the mesh, records the immutable evidence chain (its OWN reckon-db store),
%% correlates attackers across the federation, and — when an attacker crosses
%% into a second country — alerts the society through hecate-spartan's public
%% broadcast primitive. It never reaches INTO hecate-spartan; it is a peer on the
%% mesh, so the society substrate stays use-case agnostic.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {hecate_om, {git, "https://codeberg.org/hecate-services/hecate-om.git",
                 {branch, "main"}}}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

%% Elvis: the org's structural ruleset. No deep nesting (HARD, one level), no
%% nested try/catch, no if. Run via `rebar3 lint`.
{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [#{files => ["apps/*/src/**/*.erl"], ruleset => macula_min}]}
]}.

{relx, [
    {release, {hecate_sentinel, "0.1.0"}, [hecate_sentinel, sasl]},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src,    "config/vm.args.src"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod}, {include_src, false},
                    {include_erts, true}, {debug_info, strip}]}]}
]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx]}
]}.

{shell, [{apps, [hecate_sentinel]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-sentinel">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE"]},
    {main, "README.md"}
]}.
